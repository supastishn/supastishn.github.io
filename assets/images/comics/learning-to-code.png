<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<svg width="600" height="400" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="600" height="400" fill="#f8f8f8"/>
  
  <!-- First Panel - Coding Problems -->
  <rect x="50" y="50" width="220" height="300" fill="#fff" stroke="#ddd" stroke-width="2"/>
  
  <!-- Computer screen with errors -->
  <rect x="80" y="100" width="160" height="120" fill="#333"/>
  <rect x="85" y="105" width="150" height="110" fill="#efefef"/>
  
  <!-- Error text -->
  <text x="95" y="125" font-family="monospace" font-size="8" fill="red">ERROR: Syntax error</text>
  <text x="95" y="140" font-family="monospace" font-size="8" fill="red">ERROR: Undefined variable</text>
  <text x="95" y="155" font-family="monospace" font-size="8" fill="red">ERROR: Missing semicolon</text>
  <text x="95" y="170" font-family="monospace" font-size="8" fill="red">ERROR: Expected '{'</text>
  <text x="95" y="185" font-family="monospace" font-size="8" fill="red">ERROR: Too many errors</text>
  
  <!-- Person (stick figure) frustrated -->
  <circle cx="160" cy="270" r="20" fill="none" stroke="#000" stroke-width="2"/>
  <line x1="160" y1="290" x2="160" y2="320" stroke="#000" stroke-width="2"/>
  <line x1="160" y1="300" x2="130" y2="280" stroke="#000" stroke-width="2"/>
  <line x1="160" y1="300" x2="190" y2="280" stroke="#000" stroke-width="2"/>
  <line x1="160" y1="320" x2="140" y2="350" stroke="#000" stroke-width="2"/>
  <line x1="160" y1="320" x2="180" y2="350" stroke="#000" stroke-width="2"/>
  
  <!-- Sweat drops -->
  <circle cx="140" cy="260" r="3" fill="#6cf"/>
  <circle cx="145" cy="255" r="2" fill="#6cf"/>
  
  <!-- Second Panel - Reading Docs -->
  <rect x="330" y="50" width="220" height="300" fill="#fff" stroke="#ddd" stroke-width="2"/>
  
  <!-- Documentation book -->
  <rect x="370" y="130" width="140" height="100" fill="#eee" stroke="#999" stroke-width="1"/>
  <rect x="370" y="130" width="70" height="100" fill="#ddd" stroke="#999" stroke-width="1"/>
  <line x1="370" y1="130" x2="370" y2="230" stroke="#999" stroke-width="1"/>
  
  <!-- Text lines in book -->
  <line x1="380" y1="150" x2="500" y2="150" stroke="#333" stroke-width="1"/>
  <line x1="380" y1="160" x2="500" y2="160" stroke="#333" stroke-width="1"/>
  <line x1="380" y1="170" x2="500" y2="170" stroke="#333" stroke-width="1"/>
  <line x1="380" y1="180" x2="500" y2="180" stroke="#333" stroke-width="1"/>
  <line x1="380" y1="190" x2="470" y2="190" stroke="#333" stroke-width="1"/>
  <line x1="380" y1="200" x2="490" y2="200" stroke="#333" stroke-width="1"/>
  <line x1="380" y1="210" x2="460" y2="210" stroke="#333" stroke-width="1"/>
  
  <!-- Person (stick figure) reading -->
  <circle cx="440" cy="270" r="20" fill="none" stroke="#000" stroke-width="2"/>
  <line x1="440" y1="290" x2="440" y2="320" stroke="#000" stroke-width="2"/>
  <line x1="440" y1="300" x2="410" y2="270" stroke="#000" stroke-width="2"/>
  <line x1="440" y1="300" x2="470" y2="270" stroke="#000" stroke-width="2"/>
  <line x1="440" y1="320" x2="420" y2="350" stroke="#000" stroke-width="2"/>
  <line x1="440" y1="320" x2="460" y2="350" stroke="#000" stroke-width="2"/>
  
  <!-- Light bulb -->
  <circle cx="470" cy="250" r="10" fill="#ffff00" stroke="#f90" stroke-width="1"/>
  <line x1="470" y1="238" x2="470" y2="234" stroke="#f90" stroke-width="1"/>
  <line x1="478" y1="242" x2="482" y2="238" stroke="#f90" stroke-width="1"/>
  <line x1="482" y1="250" x2="486" y2="250" stroke="#f90" stroke-width="1"/>
  <line x1="478" y1="258" x2="482" y2="262" stroke="#f90" stroke-width="1"/>
  <line x1="470" y1="262" x2="470" y2="266" stroke="#f90" stroke-width="1"/>
  <line x1="462" y1="258" x2="458" y2="262" stroke="#f90" stroke-width="1"/>
  <line x1="458" y1="250" x2="454" y2="250" stroke="#f90" stroke-width="1"/>
  <line x1="462" y1="242" x2="458" y2="238" stroke="#f90" stroke-width="1"/>
  
  <!-- Title -->
  <text x="300" y="30" font-family="Arial, sans-serif" font-size="24" font-weight="bold" text-anchor="middle" fill="#333">Learning to Code</text>
</svg>